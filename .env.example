# Career GPS — Environment Variables
# Copy this file to .env.local and fill in your values

# LLM Configuration
# Set USE_MOCK=true to use mock data (no API key needed for demo)
USE_MOCK=true

# Gemini API (optional — only needed when USE_MOCK=false)
GEMINI_API_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-supabase-key
